# ─── Local development (zero config) ─────────────────────────────────────────
# Just run: npm run db:setup && npm run dev
# Everything defaults to the Docker Postgres below. No secrets needed.

# ─── Database ─────────────────────────────────────────────────────────────────
# Default points to docker-compose Postgres. Override for Neon in production.
# DATABASE_URL=postgresql://clawdboard:clawdboard@localhost:5432/clawdboard

# ─── Auth (optional for local dev) ───────────────────────────────────────────
# Without these, dev mode uses a credentials login (no GitHub OAuth needed).
# To test real OAuth locally, create a GitHub OAuth App:
#   Homepage URL: http://localhost:3001
#   Callback URL: http://localhost:3001/api/auth/callback/github
# AUTH_GITHUB_ID=your-github-oauth-app-client-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret
# AUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Public ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL=http://localhost:3001

# ─── Optional ─────────────────────────────────────────────────────────────────
# CRON_SECRET=your-cron-secret
# ADMIN_PASSWORD=your-admin-password

# ─── Analytics (Plausible — omit to disable) ─────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/your-script-id.js
